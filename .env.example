# Zoho account that SENDS the notification emails
ZOHO_USER=hello@codelaunch.com.mx

# Zoho App Password (NOT your regular password)
# How to get one:
# 1. Log into Zoho Mail → Settings → Security → App Passwords
# 2. Click "Generate New Password" → name it "CodeLaunch Site"
# 3. Paste the password below
ZOHO_APP_PASSWORD=your_zoho_app_password_here

# Email address that RECEIVES the notifications
NOTIFY_EMAIL=hello@codelaunch.com.mx

# Optional — defaults: smtp.zoho.com:587 (STARTTLS). Port 465 uses implicit SSL.
# EU accounts often need: SMTP_HOST=smtp.zoho.eu
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# With port 587, do NOT set SMTP_SECURE=true (that causes TLS errors).
# For SSL on port 465 instead: SMTP_PORT=465 and SMTP_SECURE=true

# Port (Railway sets this automatically — leave as 3001 for local dev)
PORT=3001
