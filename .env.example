# Gmail account that SENDS the notification emails
GMAIL_USER=aaronvelezcoronado@gmail.com

# Gmail App Password (NOT your regular password)
# How to get one: https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create a new app password → name it "CodeLaunch Site"
# 4. Paste the 16-character password below (spaces optional)
GMAIL_APP_PASSWORD=zeja kczl ujji ibsi


# Email address that RECEIVES the notifications (can be same as GMAIL_USER)
NOTIFY_EMAIL=aaronvelezcoronado@gmail.com

# Port (Railway sets this automatically — leave as 3001 for local dev)
PORT=3001